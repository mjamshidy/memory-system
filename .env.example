# =============================================================================
# memory-system — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# --- PostgreSQL (local) ------------------------------------------------------
PG_HOST=localhost
PG_PORT=5432
PG_USER=mjamshidy
PG_PASSWORD=
PG_DB=memory_system
PG_URL=postgresql://mjamshidy@localhost:5432/memory_system

# --- Supabase ----------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_DB_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- LLM API Keys ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
OLLAMA_BASE_URL=http://localhost:11434

# --- Default LLM assignments per task ----------------------------------------
# Options: claude, openai, gemini, ollama
LLM_GIST=claude
LLM_DIGEST=claude
LLM_ALERT_ANALYSIS=claude
LLM_QUERY=claude

# --- Telegram ----------------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=your-chat-id
TELEGRAM_ADMIN_CHAT_ID=your-admin-chat-id

# --- OpenClaw ----------------------------------------------------------------
OPENCLAW_API_URL=http://localhost:3000
OPENCLAW_API_KEY=your-openclaw-api-key
OPENCLAW_WEBHOOK_SECRET=your-webhook-secret

# --- Home Assistant ----------------------------------------------------------
HAOS_WEBHOOK_SECRET=your-haos-webhook-secret
HAOS_BASE_URL=http://homeassistant.local:8123
HAOS_LONG_LIVED_TOKEN=your-haos-token

# --- Obsidian ----------------------------------------------------------------
OBSIDIAN_VAULT_PATH=/Users/mjamshidy/Library/Mobile Documents/iCloud~md~obsidian/Documents/Obsidian Vault
OBSIDIAN_MEMORY_FOLDER=Memory

# --- iCloud Backup -----------------------------------------------------------
ICLOUD_BACKUP_PATH=/Users/mjamshidy/Library/Mobile Documents/com~apple~CloudDocs/Database Backups/memory-system
BACKUP_KEEP_DAYS=30

# --- Ingestion Server --------------------------------------------------------
INGESTION_HOST=0.0.0.0
INGESTION_PORT=8765
INGESTION_SECRET=change-this-to-a-long-random-string

# --- Analysis ----------------------------------------------------------------
ANALYSIS_BATCH_SIZE=100       # max events to process per analysis run
IMPORTANCE_ALERT_THRESHOLD=4  # events at or above this get immediate alerts
