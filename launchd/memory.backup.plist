<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.memory-system.backup</string>

    <key>ProgramArguments</key>
    <array>
        <string>BWS_BIN_PLACEHOLDER</string>
        <string>run</string>
        <string>--</string>
        <string>VENV_PYTHON_PLACEHOLDER</string>
        <string>-m</string>
        <string>sync.backup</string>
    </array>

    <key>WorkingDirectory</key>
    <string>PROJECT_DIR_PLACEHOLDER</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>BWS_ACCESS_TOKEN</key>
        <string>BWS_ACCESS_TOKEN_PLACEHOLDER</string>
    </dict>

    <!-- Run every 6 hours: 01:00, 07:00, 13:00, 19:00 -->
    <key>StartCalendarInterval</key>
    <array>
        <dict><key>Hour</key><integer>1</integer><key>Minute</key><integer>0</integer></dict>
        <dict><key>Hour</key><integer>7</integer><key>Minute</key><integer>0</integer></dict>
        <dict><key>Hour</key><integer>13</integer><key>Minute</key><integer>0</integer></dict>
        <dict><key>Hour</key><integer>19</integer><key>Minute</key><integer>0</integer></dict>
    </array>

    <key>StandardOutPath</key>
    <string>PROJECT_DIR_PLACEHOLDER/logs/backup.log</string>

    <key>StandardErrorPath</key>
    <string>PROJECT_DIR_PLACEHOLDER/logs/backup-error.log</string>
</dict>
</plist>
