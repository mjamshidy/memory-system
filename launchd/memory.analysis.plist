<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.memory-system.analysis</string>

    <key>ProgramArguments</key>
    <array>
        <string>BWS_BIN_PLACEHOLDER</string>
        <string>run</string>
        <string>--</string>
        <string>VENV_PYTHON_PLACEHOLDER</string>
        <string>-m</string>
        <string>analysis.gist_generator</string>
    </array>

    <key>WorkingDirectory</key>
    <string>PROJECT_DIR_PLACEHOLDER</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>BWS_ACCESS_TOKEN</key>
        <string>BWS_ACCESS_TOKEN_PLACEHOLDER</string>
    </dict>

    <!-- Run every 5 minutes -->
    <key>StartInterval</key>
    <integer>300</integer>

    <key>StandardOutPath</key>
    <string>PROJECT_DIR_PLACEHOLDER/logs/analysis.log</string>

    <key>StandardErrorPath</key>
    <string>PROJECT_DIR_PLACEHOLDER/logs/analysis-error.log</string>
</dict>
</plist>
