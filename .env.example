# =============================================================================
# memory-system — Non-secret configuration
#
# ⚠️  ALL API KEYS and secrets must live in Bitwarden Secrets Manager.
#     Only non-sensitive config goes here.
#
# Secrets stored in Bitwarden (managed via: python -m secrets.register):
#   ANTHROPIC_API_KEY, OPENAI_API_KEY, GOOGLE_API_KEY
#   TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID, TELEGRAM_ADMIN_CHAT_ID
#   OPENCLAW_API_KEY, OPENCLAW_WEBHOOK_SECRET
#   HAOS_WEBHOOK_SECRET, HAOS_LONG_LIVED_TOKEN
#   SUPABASE_DB_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
#   PG_PASSWORD, INGESTION_SECRET, GITHUB_WEBHOOK_SECRET
#
# Only BWS_ACCESS_TOKEN needs to be in your shell environment:
#   export BWS_ACCESS_TOKEN=<your-service-account-token>
# =============================================================================

# --- PostgreSQL (non-secret connection config) --------------------------------
PG_HOST=localhost
PG_PORT=5432
PG_USER=mjamshidy
PG_DB=memory_system

# --- Supabase ----------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co

# --- LLM task assignments (not secrets) --------------------------------------
# Options: claude:<model>, openai:<model>, gemini:<model>, ollama:<model>
LLM_GIST=claude:claude-haiku-4-5-20251001
LLM_DIGEST=claude:claude-sonnet-4-6
LLM_ALERT_ANALYSIS=claude:claude-haiku-4-5-20251001
LLM_QUERY=claude:claude-sonnet-4-6

# --- Ingestion server --------------------------------------------------------
INGESTION_HOST=0.0.0.0
INGESTION_PORT=8765

# --- Obsidian ----------------------------------------------------------------
OBSIDIAN_VAULT_PATH=/Users/mjamshidy/Library/Mobile Documents/iCloud~md~obsidian/Documents/Obsidian Vault
OBSIDIAN_MEMORY_FOLDER=Memory

# --- iCloud Backup -----------------------------------------------------------
# Leave blank to use default: ~/Library/Mobile Documents/com~apple~CloudDocs/Database Backups/memory-system
ICLOUD_BACKUP_PATH=
BACKUP_KEEP_DAYS=30

# --- OpenClaw ----------------------------------------------------------------
OPENCLAW_API_URL=http://localhost:3000

# --- Home Assistant ----------------------------------------------------------
HAOS_BASE_URL=http://homeassistant.local:8123

# --- Analysis ----------------------------------------------------------------
ANALYSIS_BATCH_SIZE=100
IMPORTANCE_ALERT_THRESHOLD=4
