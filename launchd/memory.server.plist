<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.memory-system.server</string>

    <key>ProgramArguments</key>
    <array>
        <string>BWS_BIN_PLACEHOLDER</string>
        <string>run</string>
        <string>--</string>
        <string>VENV_PYTHON_PLACEHOLDER</string>
        <string>-m</string>
        <string>uvicorn</string>
        <string>ingestion.server:app</string>
        <string>--host</string>
        <string>0.0.0.0</string>
        <string>--port</string>
        <string>8765</string>
    </array>

    <key>WorkingDirectory</key>
    <string>PROJECT_DIR_PLACEHOLDER</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>BWS_ACCESS_TOKEN</key>
        <string>BWS_ACCESS_TOKEN_PLACEHOLDER</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>PROJECT_DIR_PLACEHOLDER/logs/server.log</string>

    <key>StandardErrorPath</key>
    <string>PROJECT_DIR_PLACEHOLDER/logs/server-error.log</string>

    <key>ThrottleInterval</key>
    <integer>30</integer>
</dict>
</plist>
